{
  "name": "@ds-phx/colors",
  "version": "1.0.0",
  "description": "phx-colors — Phoenix color tokens as CSS custom properties and TypeScript constants",
  "keywords": [
    "design-tokens",
    "css-variables",
    "css-custom-properties",
    "design-system",
    "tokens",
    "colors",
    "phoenix"
  ],
  "homepage": "https://github.com/zainadeel/phx-colors#readme",
  "bugs": {
    "url": "https://github.com/zainadeel/phx-colors/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zainadeel/phx-colors.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./css": "./dist/index.css",
    "./colors": "./dist/colors.css",
    "./reset": "./dist/reset.css",
    "./globals": "./dist/globals.css",
    "./utilities": "./dist/utilities.css",
    "./themes/light": "./dist/themes/light.css",
    "./ts": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:docs": "node scripts/build-docs.mjs",
    "build:ts": "node scripts/generate-ts-constants.mjs",
    "clean": "rm -rf dist",
    "dev": "node scripts/build.mjs --watch"
  },
  "engines": {
    "node": ">=25.9.0"
  },
  "devDependencies": {
    "chokidar": "^5.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
